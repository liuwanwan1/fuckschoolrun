<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.baidu.mapapi.map.MapView
        android:id="@+id/map_create"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true" />

    <LinearLayout
        android:id="@+id/route_search_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:background="#F8FFFFFF"
        android:elevation="6dp"
        android:orientation="vertical"
        android:padding="10dp">

        <SearchView
            android:id="@+id/route_create_search_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:iconifiedByDefault="false"
            android:queryHint="@string/route_search_placeholder" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/route_search_hint"
            android:textColor="#555555"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/route_search_result_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:visibility="gone">

            <ListView
                android:id="@+id/route_search_result_list"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:divider="#22000000"
                android:dividerHeight="1dp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/route_search_container"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp"
        android:background="#80000000"
        android:padding="5dp"
        android:text="@string/route_draw_hint"
        android:textColor="#ffffff" />

    <ImageButton
        android:id="@+id/btn_create_location"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_above="@+id/layout_bottom_control"
        android:layout_alignParentStart="true"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/circle_shape_bg"
        android:padding="8dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_position" />

    <LinearLayout
        android:id="@+id/layout_bottom_control"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#ffffffff"
        android:orientation="vertical"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_create_clear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:text="@string/route_clear_button" />

            <Button
                android:id="@+id/btn_create_share"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_weight="1"
                android:text="@string/route_share_button" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_create_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/colorPrimary"
            android:text="@string/route_save_button"
            android:textColor="#ffffff" />
    </LinearLayout>
</RelativeLayout>
