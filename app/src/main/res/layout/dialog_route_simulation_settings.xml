<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <EditText
        android:id="@+id/et_dialog_settings_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/route_settings_search_hint"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp" />

    <LinearLayout
        android:id="@+id/layout_dialog_settings_letter_rail"
        android:layout_width="28dp"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_below="@id/et_dialog_settings_search"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="8dp"
        android:gravity="center"
        android:orientation="vertical" />

    <ScrollView
        android:id="@+id/scroll_dialog_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/et_dialog_settings_search"
        android:layout_toStartOf="@id/layout_dialog_settings_letter_rail"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:id="@+id/layout_dialog_settings_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:id="@+id/section_settings_link"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/route_link_ratio_label" />

                    <EditText
                        android:id="@+id/et_dialog_link_ratio_left"
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:hint="@string/route_link_ratio_hint"
                        android:inputType="numberDecimal"
                        android:text="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="4dp"
                        android:text="@string/route_link_ratio_separator" />

                    <EditText
                        android:id="@+id/et_dialog_link_ratio_right"
                        android:layout_width="64dp"
                        android:layout_height="wrap_content"
                        android:contentDescription="@string/route_link_ratio_denominator_content_desc"
                        android:enabled="false"
                        android:focusable="false"
                        android:gravity="center"
                        android:inputType="numberDecimal"
                        android:text="15" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/route_link_ratio_help"
                    android:textColor="#666666"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_settings_steps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/route_link_steps_per_meter_label" />

                    <EditText
                        android:id="@+id/et_dialog_steps_per_meter"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:hint="@string/route_link_steps_per_meter_hint"
                        android:inputType="numberDecimal"
                        android:text="1" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/route_link_steps_per_meter_help"
                    android:textColor="#666666"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_settings_loop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/route_loop_label" />

                    <EditText
                        android:id="@+id/et_dialog_loop_count"
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:inputType="number"
                        android:text="100" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/route_link_loop_help"
                    android:textColor="#666666"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_settings_nmea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/route_nmea_settings_title" />

                <Switch
                    android:id="@+id/switch_dialog_network_simulation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/route_network_simulation_label" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/route_nmea_satellite_label" />

                    <TextView
                        android:id="@+id/tv_dialog_satellite_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/route_nmea_satellite_default" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_dialog_satellite"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="11"
                    android:progress="7" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/route_nmea_signal_quality_label" />

                    <RadioGroup
                        android:id="@+id/rg_dialog_signal_quality"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rb_dialog_signal_strong"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="@string/route_nmea_signal_quality_strong" />

                        <RadioButton
                            android:id="@+id/rb_dialog_signal_medium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/route_nmea_signal_quality_medium" />

                        <RadioButton
                            android:id="@+id/rb_dialog_signal_weak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/route_nmea_signal_quality_weak" />
                    </RadioGroup>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/route_nmea_hdop_label" />

                    <TextView
                        android:id="@+id/tv_dialog_hdop_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/route_nmea_hdop_default" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_dialog_hdop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="30"
                    android:progress="15" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/route_nmea_update_interval_label" />

                    <TextView
                        android:id="@+id/tv_dialog_update_interval_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/route_nmea_update_interval_default" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_dialog_update_interval"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="19"
                    android:progress="1" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_settings_dynamic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <Switch
                    android:id="@+id/switch_dialog_dynamic_intensity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/route_speed_float" />

                <LinearLayout
                    android:id="@+id/layout_dialog_dynamic_intensity_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/route_dynamic_intensity_range_label" />

                        <EditText
                            android:id="@+id/et_dialog_intensity_range"
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:hint="@string/route_dynamic_intensity_range_hint"
                            android:inputType="numberDecimal"
                            android:text="2.0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/route_speed_unit" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/route_dynamic_intensity_frequency_label" />

                        <TextView
                            android:id="@+id/tv_dialog_intensity_frequency_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/route_dynamic_intensity_frequency_default" />
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seek_dialog_intensity_frequency"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="35" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/route_dynamic_intensity_help"
                        android:textColor="#666666"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_settings_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <Switch
                    android:id="@+id/switch_dialog_path_variation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/route_path_variation_label" />

                <LinearLayout
                    android:id="@+id/layout_dialog_path_variation_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/route_path_variation_param_label" />

                        <EditText
                            android:id="@+id/et_dialog_path_variation"
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:hint="@string/route_path_variation_hint"
                            android:inputType="numberDecimal"
                            android:text="1.0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/route_distance_unit" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/route_path_variation_help"
                        android:textColor="#666666"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_settings_floating"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <Switch
                    android:id="@+id/switch_dialog_floating_window"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/route_floating_window_label" />

                <LinearLayout
                    android:id="@+id/layout_dialog_floating_window_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_dialog_floating_window_scale"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/route_floating_window_scale_default" />

                    <SeekBar
                        android:id="@+id/seek_dialog_floating_window_scale"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="90"
                        android:progress="58" />

                    <TextView
                        android:id="@+id/tv_dialog_floating_window_button_size"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/route_floating_window_button_size_default" />

                    <SeekBar
                        android:id="@+id/seek_dialog_floating_window_button_size"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="72"
                        android:progress="44" />

                    <LinearLayout
                        android:id="@+id/view_dialog_floating_window_preview"
                        android:layout_width="140dp"
                        android:layout_height="96dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="8dp"
                        android:background="#DDE7F7"
                        android:orientation="vertical"
                        android:padding="6dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/route_floating_window_title"
                            android:textColor="#111111"
                            android:textSize="9sp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_marginTop="4dp"
                            android:layout_weight="1"
                            android:background="#F7F9FC" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_dialog_floating_preview_pause"
                                android:layout_width="44dp"
                                android:layout_height="24dp"
                                android:background="#1565C0"
                                android:gravity="center"
                                android:text="@string/route_floating_window_pause"
                                android:textColor="#FFFFFF"
                                android:textSize="8sp" />

                            <TextView
                                android:id="@+id/tv_dialog_floating_preview_resume"
                                android:layout_width="44dp"
                                android:layout_height="24dp"
                                android:layout_marginStart="6dp"
                                android:background="#2E7D32"
                                android:gravity="center"
                                android:text="@string/route_floating_window_resume"
                                android:textColor="#FFFFFF"
                                android:textSize="8sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="18dp"
                                android:layout_height="6dp"
                                android:background="#6B7280" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="6dp"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:background="#B8C3D8" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/route_floating_window_help"
                        android:textColor="#666666"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_settings_altitude"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <Switch
                    android:id="@+id/switch_dialog_altitude_variation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/route_altitude_variation_label" />

                <LinearLayout
                    android:id="@+id/layout_dialog_altitude_variation_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/route_altitude_variation_range_label" />

                        <EditText
                            android:id="@+id/et_dialog_altitude_variation_range"
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:hint="@string/route_altitude_variation_range_hint"
                            android:inputType="numberDecimal"
                            android:text="0.6" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/route_distance_unit" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/route_altitude_variation_height_label" />

                        <EditText
                            android:id="@+id/et_dialog_altitude_height"
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:hint="@string/route_altitude_variation_height_hint"
                            android:inputType="numberDecimal"
                            android:text="170" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/route_altitude_variation_height_unit" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/route_altitude_variation_probability_label" />

                        <TextView
                            android:id="@+id/tv_dialog_altitude_probability_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/route_altitude_variation_probability_default" />
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seek_dialog_altitude_probability"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="35" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/route_altitude_variation_help"
                        android:textColor="#666666"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_settings_ringtone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_dialog_ringtone"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/route_link_ringtone_default" />

                    <Button
                        android:id="@+id/btn_dialog_pick_ringtone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/route_link_ringtone_button" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/route_link_ringtone_help"
                    android:textColor="#666666"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_settings_share"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_dialog_upload_settings"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:text="@string/route_settings_upload_button" />

                <Button
                    android:id="@+id/btn_dialog_download_settings"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="@string/route_settings_download_button" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>
